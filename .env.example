# ============================================================
# ViralOS — Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# ── REQUIRED: Auth (Clerk) ────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
CLERK_SECRET_KEY=sk_test_YOUR_KEY_HERE

# Clerk redirect URLs (keep these as-is unless you change routes)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── REQUIRED: AI Script Generation (Groq) ────────────────────────────────────
# Get from: https://console.groq.com → API Keys
# Free tier: generous rate limits, no credit card required
GROQ_API_KEY=gsk_YOUR_KEY_HERE

# ── RECOMMENDED: Database (Supabase) ─────────────────────────────────────────
# Get from: https://supabase.com → Project Settings → API
# Run supabase/migrations/001_initial_schema.sql in the SQL Editor first.
# Without this: project library and render history are unavailable.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── RECOMMENDED: Video Storage (Cloudflare R2) ────────────────────────────────
# Get from: https://dash.cloudflare.com → R2 → Manage R2 API tokens
# Create bucket first: viralos-media (or set R2_BUCKET_NAME to your bucket name)
# Without this: rendered videos are returned as base64 data URLs (no persistence).
R2_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_BUCKET_NAME=viralos-media

# ── RECOMMENDED: App URL ──────────────────────────────────────────────────────
# Public URL of this Next.js app.
# In dev: http://localhost:3000 — In prod: https://your-viralos.pages.dev
NEXT_APP_URL=http://localhost:3000

# ── RECOMMENDED: Render Worker Security ──────────────────────────────────────
# Shared secret between Next.js and the Cloudflare Worker.
# Generate: openssl rand -base64 32
# Must match the RENDER_WORKER_SECRET in your Worker's wrangler config.
RENDER_WORKER_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET_32_CHARS_MIN

# ── OPTIONAL: Async Render Queue (Cloudflare Queues) ─────────────────────────
# Enables non-blocking video renders. Without this, renders run synchronously.
# Setup:
#   1. wrangler queues create viralos-render
#   2. Get CF_ACCOUNT_ID from https://dash.cloudflare.com → right sidebar
#   3. Create API token with Queue Write permission
#   4. Deploy worker: wrangler deploy --config worker/wrangler.worker.toml
CF_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
CF_API_TOKEN=YOUR_CLOUDFLARE_API_TOKEN_WITH_QUEUE_WRITE
RENDER_QUEUE_NAME=viralos-render

# ── OPTIONAL: Voice (TTS) Providers ──────────────────────────────────────────
# Tier 1 — Piper TTS (self-hosted, always free, always fallback):
#   docker run -p 8880:8880 ghcr.io/remsky/kokoro-fastapi-cpu:v0.2.2
# If not set: renders use silent audio (video still renders fine).
PIPER_API_URL=http://localhost:8880
KOKORO_API_URL=http://localhost:8880

# Tier 2 — ElevenLabs (10k chars/month free):
#   Sign up: https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=

# Tier 2 — PlayHT (12k chars/month free, fallback if ElevenLabs quota hit):
#   Sign up: https://play.ht → API Access
PLAYHT_API_KEY=
PLAYHT_USER_ID=

# ── OPTIONAL: Image Engines ───────────────────────────────────────────────────
# Default: Pollinations (always free, no key needed)

# FLUX Schnell / FLUX Dev via Replicate (~$0.003–$0.025/image):
#   Sign up: https://replicate.com — $5 free credit on signup
REPLICATE_API_TOKEN=

# Ideogram v2 (free monthly credits):
#   Sign up: https://ideogram.ai → Settings → API
IDEOGRAM_API_KEY=
