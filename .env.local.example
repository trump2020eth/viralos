# Clerk Auth — get from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
CLERK_SECRET_KEY=sk_test_YOUR_KEY_HERE

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Groq — get from https://console.groq.com (Step 2 — ACTIVE)
GROQ_API_KEY=gsk_YOUR_KEY_HERE

# Kokoro TTS — open source, self-hosted (Step 3 — ACTIVE)
# Run locally: docker run -p 8880:8880 ghcr.io/remsky/kokoro-fastapi-cpu:v0.2.2
# Or hosted: set to your deployment URL
# If not set, render uses silent audio (video still renders — add voice when ready)
KOKORO_API_URL=http://localhost:8880

# ─── Step 4 — Supabase + R2 ──────────────────────────────────────────────────

# Supabase — get from https://supabase.com → Project Settings → API
# Run supabase/migrations/001_initial_schema.sql in the SQL Editor first
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Cloudflare R2 — get from https://dash.cloudflare.com → R2 → Manage R2 API tokens
# Bucket name: viralos-media (create it first in the dashboard)
# If not set, rendered videos are returned as base64 data URLs (Step 3 fallback preserved)
R2_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_BUCKET_NAME=viralos-media

# ─── Step 5 — Cloudflare Queue async render dispatch ─────────────────────────
# If not set: /api/render/queue falls back to synchronous render (Step 3/4 behaviour)
#
# Setup steps:
#   1. wrangler queues create viralos-render
#   2. Get CF_ACCOUNT_ID from https://dash.cloudflare.com → right sidebar
#   3. Create API token: https://dash.cloudflare.com/profile/api-tokens
#      → Custom token → Queue Write permission
#   4. Set RENDER_WORKER_SECRET to any random string (32+ chars)
#   5. Add same RENDER_WORKER_SECRET to your Worker via: wrangler secret put RENDER_WORKER_SECRET
#   6. Deploy worker: cd worker && wrangler deploy --config wrangler.worker.toml
#
CF_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
CF_API_TOKEN=YOUR_CLOUDFLARE_API_TOKEN_WITH_QUEUE_WRITE
RENDER_QUEUE_NAME=viralos-render
RENDER_WORKER_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET_32_CHARS_MIN

# URL of this Next.js app — needed so the Worker can call /api/render/run
# In dev: http://localhost:3000 — in prod: https://your-viralos.pages.dev
NEXT_APP_URL=http://localhost:3000

# ─── Step 7 — 3-Tier Voice Architecture ──────────────────────────────────────
#
# Tier 1 (always free, always works — no config needed):
#   Piper TTS — self-host: docker run -p 5000:5000 rhasspy/piper
#   OR reuse Kokoro docker image (same OpenAI-compatible API):
#     docker run -p 8880:8880 ghcr.io/remsky/kokoro-fastapi-cpu:v0.2.2
#   Set PIPER_API_URL (or KOKORO_API_URL for backwards compat).
#   If neither set: renders with silent audio (video still works).
#
PIPER_API_URL=http://localhost:8880

# Tier 2 — ElevenLabs (10k chars/month free):
#   1. Sign up free at https://elevenlabs.io
#   2. Profile → API Keys → copy key
#   If not set: Tier 2 voices fall back to Piper automatically.
#
ELEVENLABS_API_KEY=

# Tier 2 — PlayHT (12k chars/month free, used if ElevenLabs quota hit):
#   1. Sign up free at https://play.ht
#   2. API Access → copy API Key and User ID
#   If not set: PlayHT voices fall back to Piper automatically.
#
PLAYHT_API_KEY=
PLAYHT_USER_ID=
#
# Tier 3 (BYOK) — user supplies their own key in the new-project UI.
# No server-side config needed. Key is used for that render only, never stored.

# ─── Image Engine — Step 8.1 upgrade ─────────────────────────────────────────
#
# Default: Pollinations (free, no key needed — baseline quality)
#
# FLUX Schnell / FLUX Dev via Replicate — big quality jump:
#   1. Sign up free at https://replicate.com
#   2. Account Settings → API Tokens → copy token
#   Free $5 credit on signup = ~250 renders at FLUX Schnell pricing (~$0.003/img)
#   Falls back to Pollinations automatically if key not set.
#
REPLICATE_API_TOKEN=

# Ideogram v2 — strong cinematic/stylized quality, free monthly credits:
#   1. Sign up free at https://ideogram.ai
#   2. Settings → API → copy key
#   Falls back to Pollinations automatically if key not set.
#
IDEOGRAM_API_KEY=
